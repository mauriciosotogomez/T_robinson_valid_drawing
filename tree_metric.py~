all_input_matrix = [
    [[5, 2, 2, 1, 1],
     [2, 5, 3, 2, 1],
     [2, 3, 5, 4, 1],
     [1, 2, 4, 5, 5],
     [1, 1, 1, 5, 5]],

    [[10, 4, 3, 2, 2],
     [4, 10, 6, 4, 2],
     [3, 6, 10, 8, 2],
     [2, 4, 8, 10, 10],
     [2, 2, 2, 10, 10]],

 [[2, 2, 1, 0, 0],
  [2, 2, 2, 1, 1],
  [1, 2, 2, 2, 1],
